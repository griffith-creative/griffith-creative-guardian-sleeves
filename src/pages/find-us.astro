---
import Layout from '../components/Layout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import PrimaryNav from '../components/PrimaryNav.astro';
import RetailerMap from '../components/RetailerMap.astro';
import RetailerList from '../components/RetailerList.astro';
import Footer from '../components/Footer.astro';
import { retailers } from '../data/retailers';
---

<Layout title="Find Us — Guardian Sleeves" description="Find card shops carrying Guardian Sleeves near you. Retailer locations in the Los Angeles area.">
  <UtilityBar slot="utility-bar" />
  <PrimaryNav slot="nav" activeSection="/find-us" />

  <!-- Hero -->
  <section class="pt-[var(--space-section)] pb-8 md:pb-12">
    <div class="container-guardian">
      <h1 class="font-display text-[48px] md:text-[64px] lg:text-[96px] leading-[0.9] uppercase text-ink">
        Find Guardian Sleeves near you.
      </h1>
      <p class="text-[16px] md:text-[18px] font-normal leading-[1.5] text-mute mt-4">
        Card shops carrying Guardian, mapped.
      </p>
    </div>
  </section>

  <!-- Map -->
  <section class="pb-[var(--space-section)]">
    <RetailerMap retailers={retailers} />
  </section>

  <!-- Retailer List (works without JS as primary content) -->
  <!-- TODO: Add search/filter UI when retailer count warrants it -->
  <RetailerList retailers={retailers} />

  <Footer slot="footer" />
</Layout>
