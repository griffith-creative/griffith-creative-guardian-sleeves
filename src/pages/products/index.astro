---
import Layout from '../../components/Layout.astro';
import UtilityBar from '../../components/UtilityBar.astro';
import PrimaryNav from '../../components/PrimaryNav.astro';
import MobileNav from '../../components/MobileNav.astro';
import ProductCard from '../../components/ProductCard.astro';
import Footer from '../../components/Footer.astro';

import productImage from '../../assets/images/guardian-black-box.png';
---

<Layout title="Sleeves — Guardian Sleeves" description="Standard size tournament-grade card sleeves. Archival polypropylene. Matte finish. 100 per pack.">
  <UtilityBar slot="utility-bar" />
  <PrimaryNav slot="nav" activeSection="/products" />
  <MobileNav slot="nav" />

  <section class="py-[var(--space-section)]">
    <div class="container-guardian">
      <div class="mb-12" data-animate="fade-up">
        <h1 class="font-display text-[64px] md:text-[96px] leading-[0.9] uppercase text-ink">SLEEVES</h1>
        <p class="text-[16px] text-mute mt-4">Standard size. Archival grade. One job done right.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-[var(--space-sm)]" data-animate="fade-up">
        <ProductCard
          name="Guardian Black"
          subtitle="Standard Size · Matte"
          price="$10.99"
          href="/products/guardian-black"
          image={productImage}
          badge="New"
        />
      </div>

      <div class="mt-12 text-center" data-animate="fade-up">
        <p class="text-[14px] font-medium text-mute">More colors coming soon.</p>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
