---
import Layout from '../components/Layout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import PrimaryNav from '../components/PrimaryNav.astro';
import Footer from '../components/Footer.astro';
import { Image } from 'astro:assets';

import originImage from '../assets/images/about/about-origin.jpg';
import philosophyImage from '../assets/images/about/about-philosophy.jpg';
import lineupImage from '../assets/images/about/about-lineup.jpg';
---

<Layout title="About | Guardian Sleeves" description="The story behind Guardian Sleeves. Built by players, for players.">
  <script slot="json-ld" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Guardian Sleeves",
    "url": "https://guardiansleeves.com",
    "description": "Tournament-grade TCG card sleeves. Built by players, for players."
  })}></script>
  <UtilityBar slot="utility-bar" />
  <PrimaryNav slot="nav" activeSection="/about" />

  <!-- Hero -->
  <section class="py-[var(--space-section)]">
    <div class="container-guardian" data-animate="fade-up">
      <h1 class="font-display text-[64px] md:text-[96px] leading-[0.9] uppercase text-ink max-w-4xl">PROTECTION IS NOT A LUXURY</h1>
      <p class="text-[16px] text-mute mt-6 max-w-xl">Guardian Sleeves exist because tournament players deserve archival-grade protection without the premium markup.</p>
    </div>
  </section>

  <!-- Origin -->
  <section class="py-[var(--space-section)] bg-soft-cloud">
    <div class="container-guardian grid grid-cols-1 md:grid-cols-2 gap-12" data-animate="fade-up">
      <div>
        <h2 class="text-[24px] font-medium leading-[1.2] text-ink mb-4">Origin</h2>
        <p class="text-[16px] text-mute leading-[1.5]">Guardian started at a card shop back table. Sleeves that split mid-round. Sleeves that clouded after a month. Sleeves priced like they were spun from gold. We asked a simple question: what if tournament-grade protection was just... standard?</p>
      </div>
      <div class="aspect-[4/3] bg-canvas overflow-hidden">
        <Image
          src={originImage}
          alt="The full Guardian Sleeves colorway lineup laid out on a table"
          widths={[640, 960, 1280]}
          sizes="(min-width: 768px) 50vw, 100vw"
          format="avif"
          quality={80}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>

  <!-- Philosophy -->
  <section class="py-[var(--space-section)]">
    <div class="container-guardian grid grid-cols-1 md:grid-cols-2 gap-12" data-animate="fade-up">
      <div class="aspect-[4/3] bg-soft-cloud overflow-hidden order-2 md:order-1">
        <Image
          src={philosophyImage}
          alt="Close-up of the matte texture on a Guardian sleeve"
          widths={[640, 960, 1280]}
          sizes="(min-width: 768px) 50vw, 100vw"
          format="avif"
          quality={80}
          class="w-full h-full object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="order-1 md:order-2">
        <h2 class="text-[24px] font-medium leading-[1.2] text-ink mb-4">Philosophy</h2>
        <p class="text-[16px] text-mute leading-[1.5]">One material. One finish. One size done right. We use archival-grade polypropylene with a matte finish tuned for shuffle feel. No glossy options that stick. No clear-front nonsense that clouds. Just the sleeve your deck deserves.</p>
      </div>
    </div>
  </section>

  <!-- What's Next -->
  <section class="py-[var(--space-section)] bg-soft-cloud">
    <div class="container-guardian" data-animate="fade-up">
      <h2 class="text-[24px] font-medium leading-[1.2] text-ink mb-4">What's Next</h2>
      <p class="text-[16px] text-mute leading-[1.5] max-w-xl mb-8">More colors. More sizes. Same standard. Guardian is built to grow with the community. Every product decision starts with what tournament players actually need at the table.</p>
      <a href="/products" class="bg-accent hover:bg-accent-hover inline-block text-canvas font-medium text-[16px] px-8 py-4 rounded-full transition-colors">
        View Sleeves
      </a>
    </div>
  </section>

  <!-- Full-width photo -->
  <div class="w-full aspect-[21/9] bg-charcoal overflow-hidden">
    <Image
      src={lineupImage}
      alt="The Guardian Sleeves colorway lineup"
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      format="avif"
      quality={80}
      class="w-full h-full object-cover"
      loading="lazy"
      decoding="async"
    />
  </div>

  <Footer slot="footer" />
</Layout>
