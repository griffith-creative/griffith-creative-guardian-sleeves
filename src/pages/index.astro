---
import Layout from '../components/Layout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import PrimaryNav from '../components/PrimaryNav.astro';
import CampaignHero from '../components/CampaignHero.astro';
import SpecBlock from '../components/SpecBlock.astro';
import LifestyleTile from '../components/LifestyleTile.astro';
import Marquee from '../components/Marquee.astro';
import Footer from '../components/Footer.astro';

import { FORMSPREE_ENDPOINT } from '../consts';

import heroImage from '../assets/images/hero-lineup.jpg';
import lifestyleImage from '../assets/images/lifestyle-lineup.jpg';
---

<Layout title="Guardian Sleeves | Max Protection. Standard Fit." description="Tournament-grade TCG card sleeves. Standard size. No compromise.">
  <script slot="json-ld" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Guardian Sleeves",
    "url": "https://guardiansleeves.com",
    "description": "Tournament-grade TCG card sleeves. Standard size. No compromise.",
    "brand": { "@type": "Brand", "name": "Guardian Sleeves" }
  })}></script>
  <UtilityBar slot="utility-bar" />
  <PrimaryNav slot="nav" activeSection="/" />

  <!-- Hero -->
  <CampaignHero
    image={heroImage}
    imageAlt="The full Guardian Sleeves colorway lineup, boxes staggered with Guardian Black front and center"
    headline="MAX PROTECTION. STANDARD FIT."
    cta="Shop Black"
    ctaHref="/products/guardian-black"
    headlineColor="canvas"
  />

  <!-- Specs -->
  <section class="py-[var(--space-section)]" data-animate="fade-up">
    <div class="container-guardian">
      <SpecBlock specs={[
        { label: 'Size', value: '66×91.5mm' },
        { label: 'Material', value: 'Archival Polypropylene' },
        { label: 'Finish', value: 'Matte' },
        { label: 'Pack', value: '120 Sleeves' },
      ]} />
    </div>
  </section>

  <!-- Why Guardian stats -->
  <section class="py-[var(--space-section)] bg-soft-cloud" data-animate="fade-up">
    <div class="container-guardian">
      <h2 class="font-display text-[48px] md:text-[64px] lg:text-[96px] leading-[0.9] uppercase text-ink" style="margin-bottom: var(--space-section);">WHY GUARDIAN</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="flex flex-col">
          <span class="font-display text-[64px] md:text-[80px] lg:text-[120px] leading-[0.9] text-ink">
            <span data-count-up="0.001" data-count-suffix="s" data-count-prefix="">0</span>
          </span>
          <p class="text-[14px] font-medium text-mute uppercase mt-2" style="letter-spacing: 0.04em;">Shuffle drag</p>
        </div>
        <div class="flex flex-col">
          <span class="font-display text-[64px] md:text-[80px] lg:text-[120px] leading-[0.9] text-ink">
            <span data-count-up="100" data-count-suffix="%">0</span>
          </span>
          <p class="text-[14px] font-medium text-mute uppercase mt-2" style="letter-spacing: 0.04em;">Archival safe</p>
        </div>
        <div class="flex flex-col">
          <span class="font-display text-[64px] md:text-[80px] lg:text-[120px] leading-[0.9] text-ink">
            <span data-count-up="3" data-count-suffix=" TCGs">0</span>
          </span>
          <p class="text-[14px] font-medium text-mute uppercase mt-2" style="letter-spacing: 0.04em;">Supported</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Lifestyle Tile -->
  <LifestyleTile
    image={lifestyleImage}
    headline="TESTED ON THE TABLE"
    cta="View Sleeves"
    ctaHref="/products"
  />

  <!-- Marquee -->
  <Marquee text="TOURNAMENT GRADE · ZERO SPLIT RATE · ARCHIVE SAFE · MATTE FINISH · 120 PER PACK" />

  <!-- Wholesale Callout -->
  <section class="py-16 md:py-24" data-animate="fade-up">
    <div class="container-guardian text-center">
      <h2 class="font-display text-[48px] md:text-[64px] lg:text-[96px] leading-[0.9] uppercase text-ink mb-6">STOCK GUARDIAN AT YOUR LGS</h2>
      <p class="text-[16px] text-mute max-w-md mx-auto mb-10">Your players already want these. Wholesale pricing, fast restock, POP materials included.</p>
      <a href="/wholesale" class="bg-accent hover:bg-accent-hover inline-block text-canvas font-medium text-[16px] px-8 py-4 rounded-full transition-colors">
        Become a Partner
      </a>
    </div>
  </section>

  <!-- Email Capture -->
  <section id="newsletter" class="py-[var(--space-section)] bg-soft-cloud" data-animate="fade-up">
    <div class="container-guardian">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-center">
        <!-- Left column (5/12) -->
        <div class="md:col-span-5">
          <h2 class="font-display text-[48px] md:text-[64px] lg:text-[96px] leading-[0.9] uppercase text-ink">Get drops first.</h2>
          <p class="text-[16px] text-mute mt-4" style="max-width: 40ch;">New colors. Restocks. No spam.</p>
        </div>
        <!-- Right column (7/12) -->
        <div class="md:col-span-7 flex flex-col gap-2">
          <form id="newsletter-form" class="flex flex-wrap gap-3 w-full max-w-xl" data-endpoint={FORMSPREE_ENDPOINT} novalidate>
            <input type="hidden" name="_subject" value="New newsletter signup | Guardian Sleeves" />
            <input type="hidden" name="source" value="Homepage newsletter" />
            <label for="email-capture" class="sr-only">Email address</label>
            <input
              type="email"
              id="email-capture"
              name="email"
              placeholder="your@email.com"
              required
              class="flex-1 border border-hairline rounded-full px-5 py-3 h-12 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors"
            />
            <button type="submit" class="bg-accent hover:bg-accent-hover text-canvas font-medium text-[16px] px-6 h-12 rounded-full transition-colors whitespace-nowrap disabled:opacity-60 disabled:cursor-not-allowed">
              Sign Up
            </button>
            <!-- Must live INSIDE the form: forms.js finds it via form.querySelector,
                 so a sibling placement makes every submit fail silently. -->
            <p data-form-status role="status" aria-live="polite" class="hidden text-[14px] font-medium leading-[1.5] basis-full"></p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<script>
  import { initAjaxForm } from '../scripts/forms.js';
  const msg = 'You’re on the list. Watch your inbox for drops and restocks.';
  initAjaxForm('newsletter-form', msg);
  document.addEventListener('astro:after-swap', () => initAjaxForm('newsletter-form', msg));
</script>
