---
import Layout from '../components/Layout.astro';
import UtilityBar from '../components/UtilityBar.astro';
import PrimaryNav from '../components/PrimaryNav.astro';
import MobileNav from '../components/MobileNav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 — Guardian Sleeves" description="Page not found.">
  <UtilityBar slot="utility-bar" />
  <PrimaryNav slot="nav" />
  <MobileNav slot="nav" />

  <section class="py-[var(--space-section)] flex-1 flex items-center justify-center">
    <div class="container-guardian text-center">
      <h1 class="font-display text-[120px] md:text-[200px] leading-none text-ink">404</h1>
      <p class="text-[16px] text-mute mt-4">This page is out of stock.</p>
      <a href="/" class="inline-block mt-8 bg-ink text-canvas font-medium text-[16px] px-8 py-4 rounded-full hover:bg-charcoal transition-colors">
        Back to Home
      </a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
