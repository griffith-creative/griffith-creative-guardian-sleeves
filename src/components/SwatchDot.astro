---
interface Props {
  color: string;
  active?: boolean;
  label?: string;
}

const { color, active = false, label } = Astro.props;
---

<button
  type="button"
  class:list={[
    'relative w-11 h-11 flex items-center justify-center rounded-full transition-shadow',
  ]}
  aria-label={label || `Color: ${color}`}
  aria-pressed={active}
>
  <span
    class:list={[
      'w-3 h-3 rounded-full',
      active && 'ring-2 ring-ink ring-offset-2',
    ]}
    style={`background-color: ${color};`}
  ></span>
</button>
