---
interface Props {
  color: string;
  active?: boolean;
  label?: string;
}

const { color, active = false, label } = Astro.props;
---

<button
  type="button"
  class:list={[
    'w-3 h-3 rounded-full transition-shadow',
    active && 'ring-2 ring-ink ring-offset-2',
  ]}
  style={`background-color: ${color};`}
  aria-label={label || `Color: ${color}`}
  aria-pressed={active}
>
</button>
