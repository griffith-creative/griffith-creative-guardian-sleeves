---
const messages = [
  'Free shipping on orders over $50',
  'Tournament-grade card protection',
  'Wholesale pricing available',
];

const track = messages.join(' · ') + ' · ';
---

<div class="bg-ink h-9 flex items-center overflow-hidden select-none" aria-hidden="true">
  <div class="utility-marquee-track flex whitespace-nowrap">
    <span class="utility-marquee-content text-[11px] font-medium tracking-[0.08em] uppercase text-canvas/70 px-2">
      {track}
    </span>
    <span class="utility-marquee-content text-[11px] font-medium tracking-[0.08em] uppercase text-canvas/70 px-2">
      {track}
    </span>
  </div>
</div>

<style>
  .utility-marquee-track {
    animation: utility-scroll 30s linear infinite;
  }

  .utility-marquee-track:hover {
    animation-play-state: paused;
  }

  @keyframes utility-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .utility-marquee-track {
      animation: none;
    }
  }
</style>
