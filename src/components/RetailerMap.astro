---
import type { Retailer } from '../data/retailers';

interface Props {
  retailers: Retailer[];
}

const { retailers } = Astro.props;
---

<div class="container-guardian">
  <div
    id="retailer-map"
    class="w-full h-[400px] md:h-[520px] bg-ink"
    style={`border-radius: var(--rounded-sm); box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2); border: 1px solid var(--charcoal);`}
    role="application"
    aria-label="Map of retailers carrying Guardian Sleeves"
  ></div>
</div>

<script define:vars={{ retailers }}>
  window.__GUARDIAN_RETAILERS = retailers;
</script>

<script>
  function initMap() {
    const mapContainer = document.getElementById('retailer-map');
    if (!mapContainer) return;
    if (mapContainer.dataset.initialized === 'true') return;

    const token = import.meta.env.PUBLIC_MAPBOX_TOKEN;
    const style = import.meta.env.PUBLIC_MAPBOX_STYLE || 'mapbox://styles/mapbox/dark-v11';

    if (!token) {
      console.warn('PUBLIC_MAPBOX_TOKEN is not set. Map will not render.');
      return;
    }

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = 'https://api.mapbox.com/mapbox-gl-js/v3.9.4/mapbox-gl.css';
    document.head.appendChild(link);

    const script = document.createElement('script');
    script.src = 'https://api.mapbox.com/mapbox-gl-js/v3.9.4/mapbox-gl.js';
    script.onload = () => {
      const mapboxgl = (window as any).mapboxgl;
      mapboxgl.accessToken = token;

      const retailers = (window as any).__GUARDIAN_RETAILERS || [];
      let activeMarkerEl: HTMLElement | null = null;

      const map = new mapboxgl.Map({
        container: 'retailer-map',
        style,
        dragRotate: false,
        pitchWithRotate: false,
        touchPitch: false,
        attributionControl: false,
        logoPosition: 'bottom-left',
      });

      map.addControl(
        new mapboxgl.NavigationControl({ showCompass: false }),
        'top-right'
      );

      const isApplePlatform =
        /(Mac|iPhone|iPod|iPad)/i.test(navigator.userAgent) &&
        /Safari/i.test(navigator.userAgent) &&
        !/Chrome|CriOS|FxiOS|EdgiOS/i.test(navigator.userAgent);

      const bounds = new mapboxgl.LngLatBounds();

      retailers.forEach((r: any) => {
        bounds.extend([r.lng, r.lat]);

        const el = document.createElement('div');
        el.className = 'guardian-marker';

        const fullAddress = `${r.address}, ${r.city}, ${r.state} ${r.postalCode}`;
        const directionsUrl = isApplePlatform
          ? `https://maps.apple.com/?daddr=${r.lat},${r.lng}`
          : `https://www.google.com/maps/dir/?api=1&destination=${r.lat},${r.lng}`;

        const popup = new mapboxgl.Popup({
          offset: 14,
          closeButton: false,
          maxWidth: '260px',
        }).setHTML(`
          <div style="font-family: 'Inter', system-ui, sans-serif; padding: 6px 2px;">
            <p style="font-size: 15px; font-weight: 600; color: #0a0a0a; margin: 0 0 4px;">${r.name}</p>
            <p style="font-size: 13px; font-weight: 400; color: #4b4b4d; margin: 0 0 8px; line-height: 1.4;">${fullAddress}</p>
            <a href="${directionsUrl}" target="_blank" rel="noopener noreferrer"
               style="display: inline-flex; align-items: center; gap: 4px; font-size: 13px; font-weight: 600; color: #0a0a0a; text-decoration: none; border-bottom: 1.5px solid #0a0a0a; padding-bottom: 1px;">
              Get directions
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
            </a>
          </div>
        `);

        const marker = new mapboxgl.Marker({ element: el })
          .setLngLat([r.lng, r.lat])
          .setPopup(popup)
          .addTo(map);

        // Active state on popup open/close
        marker.getElement().addEventListener('click', () => {
          if (activeMarkerEl && activeMarkerEl !== el) {
            activeMarkerEl.classList.remove('guardian-marker--active');
          }
          el.classList.add('guardian-marker--active');
          activeMarkerEl = el;
        });

        popup.on('close', () => {
          el.classList.remove('guardian-marker--active');
          if (activeMarkerEl === el) activeMarkerEl = null;
        });
      });

      if (retailers.length > 0) {
        map.fitBounds(bounds, {
          padding: { top: 60, bottom: 60, left: 60, right: 60 },
          maxZoom: 13,
        });
      }

      mapContainer.dataset.initialized = 'true';

      // TODO: Add marker clustering when retailer count exceeds ~50
    };

    document.head.appendChild(script);
  }

  initMap();
  document.addEventListener('astro:after-swap', initMap);
</script>

<style is:global>
  /* Markers */
  .guardian-marker {
    width: 18px;
    height: 18px;
    background: #ffffff;
    border: 2.5px solid #0a0a0a;
    border-radius: 50%;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .guardian-marker:hover {
    transform: scale(1.3);
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.5);
  }

  .guardian-marker--active {
    transform: scale(1.4);
    background: #e5e5e5;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.2), 0 3px 12px rgba(0, 0, 0, 0.5);
  }

  /* Mapbox controls */
  .mapboxgl-ctrl-group {
    border-radius: 8px !important;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.12) !important;
    border: 1px solid var(--charcoal) !important;
  }

  .mapboxgl-ctrl-group button {
    width: 32px !important;
    height: 32px !important;
  }

  /* Popup */
  .mapboxgl-popup-content {
    border-radius: 14px !important;
    padding: 14px 16px !important;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.14) !important;
    border: 1px solid var(--hairline) !important;
  }

  .mapboxgl-popup-tip {
    display: none !important;
  }

  /* Hide Mapbox logo for preview — remove if keeping Mapbox */
  .mapboxgl-ctrl-logo {
    display: none !important;
  }
</style>
