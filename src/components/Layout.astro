---
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://guardiansleeves.com');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl.href} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.href} />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <!-- Font Preload -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Page Transitions -->
    <ClientRouter />

    <!-- Structured Data -->
    <slot name="json-ld" />

    <!-- Global CSS -->
    <style is:global>
      @import '../styles/global.css';
    </style>
  </head>
  <body class="min-h-dvh flex flex-col bg-canvas text-ink">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-0 focus:left-0 focus:z-50 focus:bg-ink focus:text-canvas focus:px-4 focus:py-2">
      Skip to content
    </a>

    <header>
      <slot name="utility-bar" />
      <slot name="nav" />
    </header>

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <slot name="footer" />

    <!-- Animation System -->
    <script>
      import '../scripts/animations.js';
    </script>
  </body>
</html>
