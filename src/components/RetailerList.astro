---
import type { Retailer } from '../data/retailers';
import RetailerCard from './RetailerCard.astro';

interface Props {
  retailers: Retailer[];
}

const { retailers } = Astro.props;
---

<section class="py-[var(--space-section)] bg-soft-cloud">
  <div class="container-guardian">
    <h2 class="font-display text-[32px] md:text-[48px] leading-[0.9] uppercase text-ink mb-8">
      All locations
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {retailers.map((retailer) => (
        <RetailerCard retailer={retailer} />
      ))}
    </div>
  </div>
</section>
