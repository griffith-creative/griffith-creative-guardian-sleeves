---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  name: string;
  subtitle?: string;
  price: string;
  href: string;
  image?: ImageMetadata;
  badge?: string;
}

const { name, subtitle, price, href, image, badge } = Astro.props;
---

<article class="group">
  <a href={href} class="block">
    <!-- Image -->
    <div class="relative aspect-square bg-soft-cloud overflow-hidden">
      {image ? (
        <Image
          src={image}
          alt={name}
          widths={[320, 480, 640]}
          sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 100vw"
          format="avif"
          quality={80}
          class="w-full h-full object-cover transition-transform duration-200 ease-out group-hover:scale-[1.02]"
          loading="lazy"
          decoding="async"
        />
      ) : (
        <div class="w-full h-full flex items-center justify-center">
          <span class="text-[12px] font-medium text-stone">PHOTO: Product — {name}</span>
        </div>
      )}
      {badge && (
        <span class="absolute top-3 left-3 bg-canvas text-ink text-[12px] font-medium px-3 py-1 rounded-full border border-hairline">
          {badge}
        </span>
      )}
    </div>

    <!-- Metadata -->
    <div class="mt-2 flex flex-col gap-1">
      <h2 class="text-[16px] font-medium leading-[1.5] text-ink">{name}</h2>
      {subtitle && <p class="text-[14px] font-medium leading-[1.5] text-mute">{subtitle}</p>}
      <p class="text-[16px] font-medium leading-[1.5] text-ink">{price}</p>
    </div>
  </a>
</article>
