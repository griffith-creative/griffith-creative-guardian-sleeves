---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image?: ImageMetadata;
  imageAlt?: string;
  headline: string;
  cta: string;
  ctaHref: string;
  headlineColor?: 'canvas' | 'ink';
}

const { image, imageAlt = 'Guardian Sleeves', headline, cta, ctaHref, headlineColor = 'canvas' } = Astro.props;

const isExternal = /^https?:\/\//.test(ctaHref);
---

<section class="relative w-full aspect-[16/9] md:aspect-[21/9] bg-soft-cloud overflow-hidden flex items-end" data-cursor-vignette>
  {image ? (
    <Image
      src={image}
      alt={imageAlt}
      widths={[640, 1024, 1440, 1920]}
      sizes="100vw"
      format="avif"
      quality={80}
      class="absolute inset-0 w-full h-full object-cover hero-image-reveal"
      loading="eager"
      decoding="async"
      fetchpriority="high"
    />
  ) : (
    <div class="absolute inset-0 w-full h-full bg-ink flex items-center justify-center">
      <span class="text-[12px] font-medium text-stone">PHOTO: Hero — black sleeve fanned across play mat</span>
    </div>
  )}

  <div class="relative z-10 container-guardian pb-12 md:pb-16">
    <h1
      class:list={[
        'font-display uppercase leading-[0.9] text-[48px] md:text-[64px] lg:text-[96px] tracking-tight',
        headlineColor === 'canvas' ? 'text-canvas' : 'text-ink',
      ]}
      data-hero-headline
    >
      {headline}
    </h1>
    <a
      href={ctaHref}
      target={isExternal ? '_blank' : undefined}
      rel={isExternal ? 'noopener' : undefined}
      class="inline-block mt-6 bg-canvas text-ink font-medium text-[16px] px-6 py-3 rounded-full hover:bg-soft-cloud transition-colors"
    >
      {cta}
    </a>
  </div>
</section>

<style>
  .hero-image-reveal {
    opacity: 0;
    scale: 1.05;
    animation: hero-reveal 800ms cubic-bezier(0.16, 1, 0.3, 1) 100ms forwards;
  }

  @keyframes hero-reveal {
    to {
      opacity: 1;
      scale: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-image-reveal {
      opacity: 1;
      scale: 1;
      animation: none;
    }
  }
</style>
