---
interface Props {
  specs: { label: string; value: string }[];
}

const { specs } = Astro.props;
---

<div class="grid grid-cols-2 md:grid-cols-4 border border-hairline">
  {specs.map((spec, i) => (
    <div class:list={[
      'flex flex-col items-center justify-center py-6 px-4 text-center',
      i % 2 !== 0 && 'border-l border-hairline',
      i >= 2 && 'border-t border-hairline',
      i >= 2 && 'md:border-t-0',
      i > 0 && 'md:border-l md:border-hairline',
    ]}>
      <span class="text-[12px] font-medium leading-[1.5] text-mute uppercase tracking-wide">{spec.label}</span>
      <span class="text-[16px] font-medium leading-[1.5] text-ink mt-1">{spec.value}</span>
    </div>
  ))}
</div>
