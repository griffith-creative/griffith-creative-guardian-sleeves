---
---

<form class="flex flex-col gap-6" method="POST" action="/contact">
  <div class="flex flex-col gap-2">
    <label for="contact-name" class="text-[14px] font-medium leading-[1.5] text-ink">Name</label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      class="w-full border border-hairline rounded-full px-5 py-3 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="contact-email" class="text-[14px] font-medium leading-[1.5] text-ink">Email</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      class="w-full border border-hairline rounded-full px-5 py-3 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="contact-message" class="text-[14px] font-medium leading-[1.5] text-ink">Message</label>
    <textarea
      id="contact-message"
      name="message"
      rows="5"
      required
      class="w-full border border-hairline rounded-[18px] px-5 py-3 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors resize-none"
    ></textarea>
  </div>

  <button
    type="submit"
    class="self-start bg-ink text-canvas font-medium text-[16px] px-8 py-4 rounded-full hover:bg-charcoal transition-colors min-h-[48px]"
  >
    Send Message
  </button>
</form>
