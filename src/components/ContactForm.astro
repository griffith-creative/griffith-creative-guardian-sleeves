---
import { FORMSPREE_ENDPOINT } from '../consts';
---

<!-- AJAX submit to Formspree - stays on the branded site, shows real success/error. -->
<form id="contact-form" class="flex flex-col gap-6" data-endpoint={FORMSPREE_ENDPOINT} novalidate>
  <div class="flex flex-col gap-2">
    <label for="contact-name" class="text-[14px] font-medium leading-[1.5] text-ink">Name</label>
    <input
      type="text"
      id="contact-name"
      name="name"
      required
      class="w-full border border-hairline rounded-full px-5 py-3 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="contact-email" class="text-[14px] font-medium leading-[1.5] text-ink">Email</label>
    <input
      type="email"
      id="contact-email"
      name="email"
      required
      class="w-full border border-hairline rounded-full px-5 py-3 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors"
    />
  </div>

  <div class="flex flex-col gap-2">
    <label for="contact-message" class="text-[14px] font-medium leading-[1.5] text-ink">Message</label>
    <textarea
      id="contact-message"
      name="message"
      rows="5"
      required
      class="w-full border border-hairline rounded-[18px] px-5 py-3 text-[16px] text-ink bg-canvas focus:outline-none focus:border-ink transition-colors resize-none"
    ></textarea>
  </div>

  <button
    type="submit"
    class="self-start bg-ink text-canvas font-medium text-[16px] px-8 py-4 rounded-full hover:bg-charcoal transition-colors min-h-[48px] disabled:opacity-60 disabled:cursor-not-allowed"
  >
    Send Message
  </button>

  <p data-form-status role="status" aria-live="polite" class="hidden text-[14px] font-medium leading-[1.5]"></p>
</form>

<script>
  import { initAjaxForm } from '../scripts/forms.js';
  initAjaxForm('contact-form', 'Thanks, your message is on its way. We’ll be in touch soon.');
  document.addEventListener('astro:after-swap', () =>
    initAjaxForm('contact-form', 'Thanks, your message is on its way. We’ll be in touch soon.')
  );
</script>
