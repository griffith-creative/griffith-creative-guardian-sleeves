---
import HeadMark from '../assets/brand/guardian-head.svg';
import Wordmark from '../assets/brand/guardian-wordmark.svg';

interface Props {
  activeSection?: string;
}

const { activeSection } = Astro.props;

const navLinks = [
  { label: 'Store', href: '/products' },
  { label: 'About', href: '/about' },
  { label: 'Wholesale', href: '/wholesale' },
];
---

<nav class="sticky top-0 z-40 bg-canvas h-16 flex items-center" style="box-shadow: var(--elevation-inset);" aria-label="Primary navigation">
  <div class="container-guardian flex items-center justify-between">
    <!-- Logo -->
    <a href="/" aria-label="Guardian Home" class="flex items-center gap-2.5 text-ink">
      <HeadMark aria-hidden="true" class="h-8 w-auto" />
      <Wordmark aria-hidden="true" class="h-[15px] w-auto max-[380px]:hidden" />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-[16px] font-medium leading-[1.5] text-ink pb-1 transition-colors',
              activeSection === link.href && 'border-b-2 border-accent',
            ]}
            aria-current={activeSection === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right cluster -->
    <div class="flex items-center gap-5">
      <!-- Search removed until a real search exists; 11 SKUs don't need one
           and a dead control invites clicks. Restore from git when wired. -->

      <!-- Cart icon → opens the cart drawer; badge shows live item count -->
      <button type="button" data-open-cart aria-label="Open cart" class="relative text-ink w-11 h-11 flex items-center justify-center rounded-full hover:bg-soft-cloud transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
        <span data-cart-count class="hidden absolute -top-0.5 -right-0.5 min-w-[18px] h-[18px] px-1 flex items-center justify-center bg-accent text-canvas text-[10px] font-medium leading-none rounded-full">0</span>
      </button>

    </div>
  </div>
</nav>
