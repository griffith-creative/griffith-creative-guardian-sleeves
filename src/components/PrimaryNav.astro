---
import HeadMark from '../assets/brand/guardian-head.svg';
import Wordmark from '../assets/brand/guardian-wordmark.svg';

interface Props {
  activeSection?: string;
}

const { activeSection } = Astro.props;

const navLinks = [
  { label: 'Store', href: '/products' },
  { label: 'Find Us', href: '/find-us' },
  { label: 'About', href: '/about' },
  { label: 'Wholesale', href: '/wholesale' },
];
---

<nav class="sticky top-0 z-40 bg-canvas h-16 flex items-center" style="box-shadow: var(--elevation-inset);" aria-label="Primary navigation">
  <div class="container-guardian flex items-center justify-between">
    <!-- Logo -->
    <a href="/" aria-label="Guardian — Home" class="flex items-center gap-2.5 text-ink">
      <HeadMark aria-hidden="true" class="h-8 w-auto" />
      <Wordmark aria-hidden="true" class="h-[15px] w-auto max-[380px]:hidden" />
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-[16px] font-medium leading-[1.5] text-ink pb-1 transition-colors',
              activeSection === link.href && 'border-b-2 border-accent',
            ]}
            aria-current={activeSection === link.href ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right cluster -->
    <div class="flex items-center gap-5">
      <!-- Search pill (desktop) -->
      <button type="button" aria-label="Search" class="hidden md:flex items-center gap-2 h-11 w-56 px-5 bg-soft-cloud text-mute text-[16px] font-medium transition-colors hover:bg-hairline-soft" style="border-radius: var(--rounded-md);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-ink">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span>Search sleeves</span>
      </button>

      <!-- Search icon (mobile) -->
      <button type="button" aria-label="Search" class="md:hidden text-ink w-10 h-10 flex items-center justify-center bg-soft-cloud rounded-full transition-colors hover:bg-hairline-soft">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>

      <!-- Cart icon (links to Shopify) -->
      <!-- Phase 2 will replace this with Shopify Storefront API checkout -->
      <a href="https://guardiansleeves.com/cart" target="_blank" rel="noopener" aria-label="Shopping cart" class="text-ink w-11 h-11 flex items-center justify-center rounded-full hover:bg-soft-cloud transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </a>

    </div>
  </div>
</nav>
