---
import type { Retailer } from '../data/retailers';

interface Props {
  retailer: Retailer;
}

const { retailer } = Astro.props;
const fullAddress = `${retailer.address}, ${retailer.city}, ${retailer.state} ${retailer.postalCode}`;
---

<article class="py-5">
  <h3 class="text-[16px] font-medium leading-[1.5] text-ink">{retailer.name}</h3>
  <address class="not-italic text-[14px] font-normal leading-[1.5] text-mute mt-1">
    {retailer.address}<br />
    {retailer.city}, {retailer.state} {retailer.postalCode}
  </address>
  <a
    href="#"
    class="inline-block mt-2 text-[14px] font-medium leading-[1.5] text-ink underline underline-offset-2 hover:text-charcoal transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
    data-directions
    data-lat={retailer.lat}
    data-lng={retailer.lng}
    data-address={fullAddress}
  >
    Get directions
  </a>
</article>

<script>
  function initDirectionsLinks() {
    const isApplePlatform = /(Mac|iPhone|iPod|iPad)/i.test(navigator.userAgent) &&
      /Safari/i.test(navigator.userAgent) &&
      !/Chrome|CriOS|FxiOS|EdgiOS/i.test(navigator.userAgent);

    document.querySelectorAll<HTMLAnchorElement>('[data-directions]').forEach((link) => {
      const lat = link.dataset.lat;
      const lng = link.dataset.lng;
      if (isApplePlatform) {
        link.href = `https://maps.apple.com/?daddr=${lat},${lng}`;
      } else {
        link.href = `https://www.google.com/maps/dir/?api=1&destination=${lat},${lng}`;
      }
      link.target = '_blank';
      link.rel = 'noopener noreferrer';
    });
  }

  initDirectionsLinks();
  document.addEventListener('astro:after-swap', initDirectionsLinks);
</script>
